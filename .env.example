# X (Twitter) 账号凭据
# 从浏览器 Cookie 中获取：登录 x.com 后，打开 DevTools -> Application -> Cookies -> x.com
#
# auth_token: 认证令牌（约 40 位十六进制字符串）
X_AUTH_TOKEN=your_auth_token_here

# ct0: CSRF token（约 160 位十六进制字符串）
X_CT0=your_ct0_here

# Flask Session 密钥（建议用 python -c "import secrets; print(secrets.token_hex(32))" 生成）
# 如不设置此变量，将回退读取 users.json 中的 secret_key 字段
SECRET_KEY=your_secret_key_here

# 开发调试模式（生产环境务必设为 false 或不设置）
# FLASK_DEBUG=false
